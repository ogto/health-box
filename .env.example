# Backend API origin. Do not include a trailing slash.
HEALTH_BOX_API_BASE_URL=https://api.example.com

# Public storefront domain routing.
STORE_ROOT_DOMAIN=everybuy.co.kr
ADMIN_HOSTNAME=admin.everybuy.co.kr

# Admin login and cookie verification.
ADMIN_PASSWORD=change-me
ADMIN_SESSION_TOKEN=replace-with-a-long-random-token

# Member session cookie signing. Keep this stable across deployments.
MEMBER_SESSION_SECRET=replace-with-a-long-random-secret
